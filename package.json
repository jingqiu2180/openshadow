{
  "name": "openhanako-inspired",
  "version": "0.1.0",
  "description": "A personal AI agent with memory and soul - inspired by OpenHanako",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc && node scripts/copy-desktop-assets.js",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "electron": "tsc -p desktop/tsconfig.json && electron dist/desktop/main.js",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\"",
    "electron:build": "npm run build && tsc -p desktop/tsconfig.json && electron-builder --dir",
    "electron:dist": "npm run build && tsc -p desktop/tsconfig.json && electron-builder"
  },
  "build": {
    "appId": "com.openhanako.inspired",
    "productName": "小Hanako",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@larksuiteoapi/node-sdk": "^1.5.3",
    "better-sqlite3": "^11.9.1",
    "hono": "^4.7.11",
    "node-cron": "^3.0.3",
    "openai": "^4.87.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.9",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.6",
    "@types/ws": "^8.5.14",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "wait-on": "^9.0.10"
  }
}