{
  "name": "openshadow",
  "version": "0.3.32",
  "description": "OpenShadow — Your AI shadow that works in the dark. Autonomous patrol, task execution, file monitoring.",
  "type": "module",
  "author": {
    "name": "jingqiu2180",
    "email": "jingqiu2180@users.noreply.github.com"
  },
  "license": "Apache-2.0",
  "main": "desktop/bootstrap.cjs",
  "scripts": {
    "dev": "tsx watch start.ts",
    "dev:web": "node scripts/dev-web.js",
    "build": "node scripts/build-server.mjs && node scripts/copy-desktop-assets.js",
    "build:server": "node scripts/build-server.mjs",
    "start": "node dist-server-bundle/index.js",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:functional": "playwright test --config=playwright.functional.config.ts",
    "typecheck": "tsc --noEmit",
    "electron:main": "vite build --config vite.config.main.js",
    "electron:preload": "vite build --config vite.config.preload.js",
    "electron": "npm run electron:main && npm run electron:preload && node scripts/copy-desktop-assets.js && node scripts/start-electron.mjs",
    "desktop:vite": "vite --config desktop/vite.config.ts",
    "desktop:build": "vite build --config desktop/vite.config.ts && node -e \"const fs=require('fs'); fs.cpSync('desktop/src/lib','desktop/dist-renderer/lib',{recursive:true}); fs.cpSync('desktop/src/modules','desktop/dist-renderer/modules',{recursive:true}); fs.cpSync('desktop/src/locales','desktop/dist-renderer/locales',{recursive:true}); fs.cpSync('desktop/src/themes','desktop/dist-renderer/themes',{recursive:true}); console.log('Static assets copied.')\"",
    "electron:dev": "concurrently -k -n server,vite,electron -c blue,magenta,green \"npm run dev\" \"npm run desktop:vite\" \"wait-on tcp:3000 tcp:5280 && node scripts/start-electron.mjs\"",
    "electron:build": "npm run desktop:build && npm run build && npm run electron && electron-builder --dir",
    "electron:dist": "npm run build && npm run desktop:build && npm run electron && electron-builder",
    "pack": "npm run electron:build",
    "dist:win": "npm run electron:build && electron-builder --win nsis --publish never",
    "dist:linux": "npm run electron:build && electron-builder --linux AppImage deb --publish never",
    "dist:mac": "npm run electron:build && cross-env SKIP_NOTARIZE=true electron-builder --mac dmg zip --publish never",
    "dist:all": "npm run electron:build && cross-env SKIP_NOTARIZE=true electron-builder -mwl --publish never",
    "postinstall": "node scripts/patch-pi-sdk.cjs",
    "test:unit": "vitest run",
    "test:e2e:workspace": "playwright test tests/e2e/workspace.web.spec.ts",
    "test:e2e:chat": "playwright test tests/e2e/chat.web.spec.ts",
    "test:e2e:settings": "playwright test tests/e2e/settings.web.spec.ts",
    "test:e2e:jian": "playwright test tests/e2e/jian.web.spec.ts",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run test:unit -- --reporter=default && npm run test:e2e -- --reporter=dot"
  },
  "build": {
    "appId": "com.openshadow.app",
    "productName": "OpenShadow",
    "asar": true,
    "asarUnpack": [
      "desktop/wizard/preload.js"
    ],
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "desktop/bootstrap.cjs"
    },
    "files": [
      "desktop/main.bundle.cjs",
      "desktop/bootstrap.cjs",
      "desktop/preload.bundle.cjs",
      "desktop/dist-renderer/**",
      "desktop/src/**/*.{html,icns,ico,png,svg,json}",
      "desktop/src/assets/**",
      "package.json",
      "!packages/**",
      "!**/node_modules/**",
      "desktop/wizard/**",
      "node_modules/ws/**"
    ],
    "extraResources": [
      {
        "from": "desktop/src/assets",
        "to": "assets"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "desktop/entitlements.mac.plist",
      "entitlementsInherit": "desktop/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "dist-server/mac-arm64",
          "to": "server"
        }
      ]
    },
    "dmg": {
      "title": "OpenShadow",
      "contents": [
        {
          "x": 180,
          "y": 220
        },
        {
          "x": 420,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jingqiu2180",
        "repo": "openshadow"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/src/icon.ico",
      "executableName": "OpenShadow",
      "artifactName": "${productName}-${version}-Windows-${arch}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "extraResources": [
        {
          "from": "dist-server/win-x64",
          "to": "server"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "OpenShadow",
      "include": "build/installer.nsh",
      "installerIcon": "desktop/src/icon.ico",
      "uninstallerIcon": "desktop/src/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "jingqiu2180 <jingqiu2180@users.noreply.github.com>",
      "category": "Utility",
      "icon": "desktop/src/icon.png",
      "artifactName": "${productName}-${version}-Linux-${arch}.${ext}",
      "extraResources": [
        {
          "from": "dist-server/linux-x64",
          "to": "server"
        }
      ]
    }
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/view": "6.43.0",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "@mariozechner/pi-ai": "0.70.5",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@node-rs/jieba": "2.0.1",
    "@tiptap/core": "^3.22.0",
    "@tiptap/extension-bold": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "extract-zip": "^2.0.1",
    "hono": "^4.12.9",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "katex": "^0.16.39",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.3.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "11.10.1",
    "motion": "12.40.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "node-pty": "1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.87.3",
    "pdf-parse": "^2.4.5",
    "proxy-agent": "6.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "typebox": "1.1.34",
    "undici": "^7.24.7",
    "unpdf": "1.6.2",
    "ws": "^8.21.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.9",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.14",
    "@vercel/nft": "^1.10.2",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "wait-on": "^9.0.10"
  }
}
