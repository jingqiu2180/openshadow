{
  "name": "remu",
  "version": "0.1.0",
  "description": "一个有个性和记忆的 AI 助手 - 从零开始异世界生活·雷姆",
  "type": "module",
  "scripts": {
    "dev": "set \"PATH=%USERPROFILE%\\.workbuddy\\binaries\\node\\versions\\22.22.2;%PATH%\" && tsx watch start.ts",
    "build": "tsc && node scripts/copy-desktop-assets.js",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "electron": "tsc -p desktop/tsconfig.json && node scripts/copy-desktop-assets.js && node -e \"const fs=require('fs'); fs.renameSync('dist/desktop/electron-main.js','dist/desktop/electron-main.cjs'); fs.renameSync('dist/desktop/preload.js','dist/desktop/preload.cjs')\" && node scripts/start-electron.mjs",
    "desktop:vite": "vite --config desktop/vite.config.ts",
    "desktop:build": "vite build --config desktop/vite.config.ts && node -e \"const fs=require('fs'); fs.cpSync('desktop/src/lib','desktop/dist-renderer/lib',{recursive:true}); fs.cpSync('desktop/src/modules','desktop/dist-renderer/modules',{recursive:true}); fs.cpSync('desktop/src/locales','desktop/dist-renderer/locales',{recursive:true}); console.log('Static assets copied.')\"",
    "electron:dev": "concurrently -k -n server,vite,electron -c blue,magenta,green \"npm run dev\" \"npm run desktop:vite\" \"wait-on tcp:3000 tcp:5173 && node scripts/start-electron.mjs\"",
    "electron:build": "npm run build && npm run desktop:build && tsc -p desktop/tsconfig.json && electron-builder --dir",
    "electron:dist": "npm run build && npm run desktop:build && tsc -p desktop/tsconfig.json && electron-builder"
  },
  "build": {
    "appId": "com.remu.agent",
    "productName": "Rem Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/electron-main.cjs"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/view": "6.43.0",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@mariozechner/pi-ai": "0.70.5",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@node-rs/jieba": "2.0.1",
    "@tiptap/core": "^3.22.0",
    "@tiptap/extension-bold": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "extract-zip": "^2.0.1",
    "hono": "^4.12.9",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "katex": "^0.16.39",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "11.10.1",
    "motion": "12.40.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "node-pty": "1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.87.3",
    "pdf-parse": "^2.4.5",
    "proxy-agent": "6.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "typebox": "1.1.34",
    "undici": "7.24.7",
    "unpdf": "1.6.2",
    "ws": "^8.18.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.9",
    "@types/node-cron": "^3.0.11",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "wait-on": "^9.0.10"
  }
}
