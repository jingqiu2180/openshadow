{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["core/**/*", "server/**/*", "channels/**/*", "db/**/*", "hub/**/*", "plugins/**/*", "lib/**/*", "shared/**/*", "desktop/src/electron-main.ts", "desktop/src/preload.ts", "desktop/src/store.ts", "desktop/src/model-manager.ts", "packages/plugin-protocol/**/*", "packages/plugin-sdk/**/*", "packages/plugin-runtime/**/*"],
  "exclude": ["node_modules", "dist", "tests", "desktop/src/react", "desktop/vite-test.config.ts"]
}
